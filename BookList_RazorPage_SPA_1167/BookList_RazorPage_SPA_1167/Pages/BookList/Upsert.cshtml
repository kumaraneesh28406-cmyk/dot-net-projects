@page
@model BookList_RazorPage_SPA_1167.Pages.BookList.UpsertModel
@{  
    var title = Model.Book.Id != 0 ? "Edit Book" : "New Book";  
    var saveUpdate = Model.Book.Id != 0 ? "Update" : "Save";  
}  

<h2 class="text-primary text-center">@title</h2>  
<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if(Model.Book.Id!= 0)
    {
        <input type="hidden" asp-for="Book.Id"/>
    }
    <div class="container rounded border">
        <div class="form-group row m-2 p-2">
            <div class="col-4">
                <label asp-for= "Book.Title">
                    </label>
            </div>
            <div class="col-8">
                <input asp-for="Book.Title" class="form-control" />
                <span asp-validation-for="Book.Title" class="text-danger"></span>
        </div>
        </div>
        <div class="form-group row">
            <div class="col-4">
                <label asp-for="Book.Description">
                </label>
            </div>
            <div class="col-8">
                <input asp-for="Book.Description" class="form-control" />
                <span asp-validation-for="Book.Description" class="text-danger"></span>
            </div>
        </div>

            <div class="form-group row m-2 p-2">
                <div class="col-4">
                    <label asp-for="Book.Author">
                    </label>
                </div>
                <div class="col-6">
                    <input asp-for="Book.Author" class="form-control" />
                    <span asp-validation-for="Book.Author" class="text-danger"></span>
                </div>
        </div>

                <div class="form-group row m-2 p-2">
                    <div class="col-4">
                        <label asp-for="Book.ISBN">    </label>
                    </div>
                    <div class="col-4">
                        <input asp-for="Book.ISBN" class="form-control" />
                        <span asp-validation-for="Book.ISBN" class="text-danger"></span>
                        </div>
                </div>
            <div class="form-group row m-2 p-2">
            <div class="col-4">
                <label asp-for= "Book.Price">     </label>
            </div>
            <div class="col-4">
                <input asp-for="Book.Price" class="form-control" />
                <span asp-validation-for="Book.Price" class="text-danger"></span>
        </div>
        </div>
                    
           <div class="form-group row m-2 p-2">
            <div class="col-4 offset-4">
         <button type="submit" class="btn btn-info form-control">@saveUpdate
         </button>
            </div>
    <div class="col-4">
        <a asp-page="Index" class="btn btn-success form-control"> back to list </a> 
    </div>
     </div>
    </div>

</form>
@section scripts
{
    <partial name="_ValidationScriptsPartial"/>
}
                   
        
